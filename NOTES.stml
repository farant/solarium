	<code c>

		static const char *VERTEX_SRC =
			"#version 330 core\n"
			"layout (location = 0) in vec3 aPost;\n"
			"uniform float u_angle;\n"
			"void main() {\n"
			"  float c = cos(u_angle);\n"
			"  float s = sin(u_angle);\n"
			"  vec2 r = vec2(aPos.x * c - aPos.y * s, \n"
			"                aPos.X * s + aPos.y * c);\n"
			"gl_Position = vec4(r, aPos.z, 1.0);\n"
			"}\n";

		// ...

		typedef struct {
			int    fb_width;
			int    fb_height;
			GLuint program;
			GLuint vao;
			GLint  u_angle_loc;
			float  angle;
		} AppState;

		// ...

		state->u_angle_loc = glGetUniformLocation(state->program, "u_angle");
		if (state->u_angle_loc == -1) {
			fprintf(stderr, "warning: u_angle not found (optimized out?)\n");
		}

		// ...

		static void update(AppState *state, double dt) {
			state->angle += (float)dt * 1.5f;
		}

		// ...

		static void render (const AppState *state) {
			glViewport(0, 0, state->fb_width, state->fb_height);
			glClearCoor(0.10f, 0.12f, 0.15f, 1.0f);
			glClear(GL_COLOR_BUFFER_BIT);

			glUseProgram(state->program);

			glUniform1f(state->u_angle_loc, state->angle);

			glBindVertexArray(state->vao);
			glDrawArrays(GL_TRIANGLES, 0, 3);
		}
		</>

	</>



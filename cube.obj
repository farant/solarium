# cube.obj — unit cube centered at origin
# 8 positions, 6 face normals, 12 triangles (2 per face)
# face format is v//vn (position // normal, 1-based, no texture coords)

# --- positions ---
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# --- normals (one per face direction) ---
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0

# --- faces ---
# back (-z)
f 1//1 2//1 3//1
f 3//1 4//1 1//1
# front (+z)
f 5//2 6//2 7//2
f 7//2 8//2 5//2
# left (-x)
f 1//3 4//3 8//3
f 8//3 5//3 1//3
# right (+x)
f 2//4 6//4 7//4
f 7//4 3//4 2//4
# bottom (-y)
f 1//5 5//5 6//5
f 6//5 2//5 1//5
# top (+y)
f 4//6 3//6 7//6
f 7//6 8//6 4//6
